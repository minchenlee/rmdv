# Cloudflare Workers static-asset headers.
# Security + caching for the rmdv landing site.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  Cross-Origin-Opener-Policy: same-origin
  X-Frame-Options: DENY
  Content-Security-Policy: default-src 'self'; base-uri 'self'; script-src 'self' 'sha256-cQMvjaj2mTY9MNXhXyX5u6KCM8l8fOpM7SuRi46uTVw=' 'sha256-nAldIcx5T94hBk+qvFZa2z1lzCJYNSGgwArw0sIKcVw=' https://static.cloudflareinsights.com; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://api.github.com https://cloudflareinsights.com; form-action 'none'; frame-ancestors 'none'; object-src 'none'; manifest-src 'self'; upgrade-insecure-requests

# Long-lived, content-stable assets.
/assets/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Always revalidate the entry document so deploys go live immediately.
/
  Cache-Control: public, max-age=0, must-revalidate

/index.html
  Cache-Control: public, max-age=0, must-revalidate
